<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile</title>
</head>

<body>

    <h1>My Profile</h1>

    <hr>

    <h3>First Name</h3>
    <p>
        <%= user.firstName %>
    </p>

    <h3>Last Name</h3>
    <p>
        <%= user.lastName %>
    </p>

    <h3>Email</h3>
    <p>
        <%= user.email %>
    </p>

    <h3>Role</h3>
    <p>
        <%= user.role %>
    </p>

    <br>

    <a href="/home">Home</a>
    <a href="/logout">Logout</a>

</body>

</html>