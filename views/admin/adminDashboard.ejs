<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/admin/dashboard">
                E-Commerce Admin Panel
            </a>

            <div>
                <a href="/" class="btn btn-outline-light btn-sm me-2">
                    Home
                </a>

                <a href="/profile" class="btn btn-outline-info btn-sm me-2">
                    Profile
                </a>

                <a href="/logout" class="btn btn-danger btn-sm">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">

        <div class="text-center mb-5">
            <h2>Welcome Admin 👋</h2>
            <p class="text-muted">
                Manage your E-Commerce Website
            </p>
        </div>

        <div class="row g-4">

            <!-- Categories -->
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">

                        <h3>📂</h3>

                        <h4 class="mt-3">Categories</h4>

                        <p class="text-muted">
                            Add, edit and delete product categories.
                        </p>

                        <a href="/categories" class="btn btn-primary">
                            Manage Categories
                        </a>

                    </div>
                </div>
            </div>

            <!-- Products -->
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">

                        <h3>📦</h3>

                        <h4 class="mt-3">Products</h4>

                        <p class="text-muted">
                            Manage all products in the store.
                        </p>

                        <a href="/products" class="btn btn-success">
                            Manage Products
                        </a>

                    </div>
                </div>
            </div>

            <!-- Orders -->
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">

                        <h3>📑</h3>

                        <h4 class="mt-3">Orders</h4>

                        <p class="text-muted">
                            View and manage customer orders.
                        </p>

                        <a href="/orders" class="btn btn-warning text-white">
                            Manage Orders
                        </a>

                    </div>
                </div>
            </div>

            <!-- Users -->
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">

                        <h3>👥</h3>

                        <h4 class="mt-3">Users</h4>

                        <p class="text-muted">
                            View registered users.
                        </p>

                        <a href="/users" class="btn btn-info text-white">
                            Manage Users
                        </a>

                    </div>
                </div>
            </div>

            <!-- Profile -->
            <div class="col-md-4">
                <div class="card shadow h-100">
                    <div class="card-body text-center">

                        <h3>🙍</h3>

                        <h4 class="mt-3">Profile</h4>

                        <p class="text-muted">
                            View your admin profile.
                        </p>

                        <a href="/profile" class="btn btn-secondary">
                            My Profile
                        </a>

                    </div>
                </div>
            </div>

            <!-- Logout -->
            <div class="col-md-4">
                <div class="card shadow h-100 border-danger">
                    <div class="card-body text-center">

                        <h3>🚪</h3>

                        <h4 class="mt-3 text-danger">Logout</h4>

                        <p class="text-muted">
                            Sign out from the admin panel.
                        </p>

                        <a href="/logout" class="btn btn-danger">
                            Logout
                        </a>

                    </div>
                </div>
            </div>

        </div>

    </div>

</body>

</html>